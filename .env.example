# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# Public — safe to expose in the browser bundle
NEXT_PUBLIC_API_URL=https://api.send2app.com
NEXT_PUBLIC_SITE_URL=https://www.send2app.com
NEXT_PUBLIC_ANALYTICS_KEY=
NEXT_PUBLIC_FF_BASE_URL=

# NextAuth — server-side only
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>
NEXTAUTH_URL=http://localhost:3000

# Server-side only secrets (no NEXT_PUBLIC_ prefix)
API_SECRET_KEY=
